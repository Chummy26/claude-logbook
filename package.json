{
  "name": "logbook-cc",
  "version": "0.1.0",
  "description": "Persistent memory + surgical patch engine + real-time context HUD for Claude Code",
  "main": "dist/server.js",
  "type": "module",
  "bin": {
    "logbook-cc": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "mcp:init": "npm run build && node dist/cli.js init .",
    "start": "node dist/cli.js",
    "test": "npm run build && node --test test/readme-end-to-end.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "claude",
    "claude-code",
    "memory",
    "context",
    "patch-engine",
    "tree-sitter",
    "ai",
    "llm",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "web-tree-sitter": "^0.24.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
